{
  "expo": {
    "name": "Chiavi",
    "slug": "selfly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "chiavi",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FEF7E4",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chiavi.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Chiavi needs access to your photo library to add photos of your property to your listing.",
        "NSCameraUsageDescription": "Chiavi needs camera access to take photos of your property for your listing.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FEF7E4"
      },
      "package": "com.chiavi.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C4A265"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "de3539fa-a711-4803-9cbf-3d0465b6d086"
      }
    },
    "owner": "gija-brands"
  }
}
